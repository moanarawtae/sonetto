{
  "name": "sonetto",
  "version": "1.0.0",
  "description": "Sonetto \u2013 local-first music player inspired by modern streaming UX.",
  "main": "dist/main/index.cjs",
  "type": "commonjs",
  "author": "Sonetto Team",
  "license": "MIT",
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "npm run build:main && npm run build:preload && concurrently -k \"npm:dev:renderer\" \"npm:dev:processes\"",
    "dev:renderer": "vite dev --host",
    "dev:processes": "concurrently -k \"npm:watch:main\" \"npm:watch:preload\" \"npm:launch:electron\"",
    "watch:main": "tsc -p tsconfig.main.json --watch --preserveWatchOutput",
    "watch:preload": "tsc -p tsconfig.preload.json --watch --preserveWatchOutput",
    "launch:electron": "wait-on \"file:dist/main/index.cjs\" \"file:dist/preload/index.cjs\" tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "npm run clean && npm run build:renderer && npm run build:main && npm run build:preload",
    "clean": "rimraf dist .vite",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "vitest",
    "e2e": "playwright test"
  },
  "build": {
    "appId": "com.sonetto.desktop",
    "productName": "Sonetto",
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    },
    "mac": {
      "category": "public.app-category.music",
      "artifactName": "Sonetto-${version}.${ext}",
      "target": ["dmg"]
    },
    "win": {
      "target": ["nsis"],
      "artifactName": "Sonetto-${version}.${ext}"
    },
    "linux": {
      "target": ["AppImage"],
      "category": "AudioVideo",
      "artifactName": "Sonetto-${version}.${ext}"
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.4.1",
    "chokidar": "^3.6.0",
    "classnames": "^2.5.1",
    "electron-log": "^5.2.1",
    "electron-updater": "^6.6.2",
    "music-metadata": "^11.9.0",
    "nanocolors": "^0.2.13",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "react-use": "^17.6.0",
    "react-virtualized-auto-sizer": "^1.0.11",
    "react-window": "^1.8.10",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@playwright/test": "^1.56.1",
    "@types/better-sqlite3": "^7.6.9",
    "@types/node": "^20.19.2",
    "@types/react": "^18.3.26",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^32.3.3",
    "electron-builder": "^26.0.12",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.9.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^15.14.0",
    "playwright": "^1.56.1",
    "postcss": "^8.5.6",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3",
    "vite": "^7.1.10",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.1"
  }
}
