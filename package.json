{
  "name": "sonetto",
  "version": "0.1.0",
  "description": "Sonetto – Electron music player inspired by modern streaming UX.",
  "main": "dist/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "npm run build:main && npm run build:preload && concurrently -k \"npm:dev:renderer\" \"npm:dev:processes\"",
    "dev:renderer": "vite dev --host",
    "dev:processes": "concurrently -k \"npm:watch:main\" \"npm:watch:preload\" \"npm:launch:electron\"",
    "watch:main": "tsc -p tsconfig.main.json --watch --preserveWatchOutput",
    "watch:preload": "tsc -p tsconfig.preload.json --watch --preserveWatchOutput",
    "launch:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "npm run clean && npm run build:renderer && npm run build:main && npm run build:preload",
    "clean": "rimraf dist",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest",
    "e2e": "playwright test",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.sonetto.app",
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    },
    "mac": {
      "category": "public.app-category.music",
      "target": ["dmg"]
    },
    "win": {
      "target": ["nsis"]
    },
    "linux": {
      "target": ["AppImage"],
      "category": "AudioVideo"
    }
  },
  "dependencies": {
    "better-sqlite3": "^9.4.0",
    "classnames": "^2.5.1",
    "electron-updater": "^6.1.8",
    "music-metadata": "^9.0.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.2",
    "@types/node": "^20.11.17",
    "@types/react": "^18.2.21",
    "@types/react-dom": "^18.2.7",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.2.3",
    "electron-builder": "^24.6.4",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "playwright": "^1.41.2",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vitest": "^0.34.6",
    "rimraf": "^5.0.5",
    "wait-on": "^7.0.1"
  }
}
