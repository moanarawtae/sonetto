{
  "name": "sonetto",
  "version": "0.1.0",
  "description": "Sonetto \u2013 Electron music player inspired by modern streaming UX.",
  "main": "dist/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "npm run build:main && npm run build:preload && concurrently -k \"npm:dev:renderer\" \"npm:dev:processes\"",
    "dev:renderer": "vite dev --host",
    "dev:processes": "concurrently -k \"npm:watch:main\" \"npm:watch:preload\" \"npm:launch:electron\"",
    "watch:main": "tsc -p tsconfig.main.json --watch --preserveWatchOutput",
    "watch:preload": "tsc -p tsconfig.preload.json --watch --preserveWatchOutput",
    "launch:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "npm run clean && npm run build:renderer && npm run build:main && npm run build:preload",
    "clean": "rimraf dist",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest",
    "e2e": "playwright test",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.sonetto.app",
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    },
    "mac": {
      "category": "public.app-category.music",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "AudioVideo"
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.4.1",
    "classnames": "^2.5.1",
    "electron-updater": "^6.6.2",
    "music-metadata": "^11.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/node": "^20.19.2",
    "@types/react": "^18.3.26",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^32.3.3",
    "electron-builder": "^26.0.12",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "playwright": "^1.56.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3",
    "vite": "^7.1.10",
    "vitest": "^3.2.4",
    "rimraf": "^6.0.1",
    "wait-on": "^9.0.1"
  }
}
